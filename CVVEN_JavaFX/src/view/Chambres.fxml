<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainContainer" prefHeight="720.0"
	prefWidth="1291.0" xmlns="http://javafx.com/javafx/22"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="controller.ChambreController">

	<stylesheets>
		<URL value="@style.css" />
		<URL value="@../application/application.css" />
	</stylesheets>

	<top>
		<HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0"
			styleClass="header-panel" BorderPane.alignment="CENTER">
			<children>
				<Label styleClass="title-label" text="CVVEN" textFill="WHITE" />
				<Separator orientation="VERTICAL" prefHeight="40.0" />
				<Label styleClass="subtitle-label"
					text="Système de Gestion Hôtelière" textFill="#bdc3c7" />
				<Region HBox.hgrow="ALWAYS" />
				<Label style="-fx-font-size: 14px;" text="Administrateur"
					textFill="WHITE" />
			</children>
		</HBox>
	</top>

	<left>
		<VBox prefHeight="640.0" prefWidth="360.0" spacing="10.0"
			styleClass="sidebar" BorderPane.alignment="CENTER">
			<children>
				<Label style="-fx-font-weight: bold; -fx-padding: 0 0 10 10;"
					text="MENU GÉNÉRAL" textFill="#95a5a6" />

                <Button fx:id="btnAcceuil" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goAcceuil" prefHeight="50.0" styleClass="menu-button" text="Acceuil">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>
                
				<Button fx:id="btnChambres" maxWidth="1.7976931348623157E308"
					prefHeight="50.0"
					style="-fx-background-color: #2C3E50; -fx-border-color: #4A90E2; -fx-border-width: 0 0 0 3;"
					styleClass="menu-button" text="Gestion des chambres">
					<padding>
						<Insets left="20.0" />
					</padding>
				</Button>

				<Button fx:id="btnReservations"
					maxWidth="1.7976931348623157E308" prefHeight="50.0"
					styleClass="menu-button" text="Gestion des réservations">
					<padding>
						<Insets left="20.0" />
					</padding>
				</Button>

				<Button fx:id="btnClients" maxWidth="1.7976931348623157E308"
					prefHeight="50.0" styleClass="menu-button"
					text="Gestion des clients">
					<padding>
						<Insets left="20.0" />
					</padding>
				</Button>

				<Button fx:id="btnPersonnel"
					maxWidth="1.7976931348623157E308" prefHeight="50.0"
					styleClass="menu-button" text="Gestion du personnel">
					<padding>
						<Insets left="20.0" />
					</padding>
				</Button>

				<Button fx:id="btnFacturation"
					maxWidth="1.7976931348623157E308" prefHeight="50.0"
					styleClass="menu-button" text="Facturation">
					<padding>
						<Insets left="20.0" />
					</padding>
				</Button>

				<Region VBox.vgrow="ALWAYS" />
				<Button fx:id="btnDeconnexion"
					maxWidth="1.7976931348623157E308" onAction="#deconnexion"
					prefHeight="45.0" styleClass="logout-button" text="Déconnexion" />
			</children>
		</VBox>
	</left>

	<center>
		<VBox spacing="20.0" style="-fx-padding: 30;"
			BorderPane.alignment="CENTER">
			<children>
				<Label style="-fx-font-size: 26px; -fx-font-weight: bold;"
					text="Liste des Chambres" textFill="#2c3e50" />

				<HBox alignment="CENTER_LEFT" spacing="15.0"
					styleClass="toolbar-panel">
					<children>
						<TextField fx:id="txtRecherche" prefWidth="250.0"
							promptText="Rechercher (Numéro, Type...)" />

						<ComboBox fx:id="comboType" prefWidth="150.0"
							promptText="Type de chambre"
							style="-fx-background-color: #F0F2F5;" />
						<ComboBox fx:id="comboStatut" prefWidth="150.0"
							promptText="Statut" style="-fx-background-color: #F0F2F5;" />

						<Region HBox.hgrow="ALWAYS" />

						<Button fx:id="btnAjouter" mnemonicParsing="false"
							onAction="#ajtChambre" prefHeight="35.0"
							styleClass="action-btn-success" text="+ Nouvelle Chambre" />
					</children>
				</HBox>
				<TableView fx:id="tableChambres" VBox.vgrow="ALWAYS">
					<columns>
						<TableColumn fx:id="colId" prefWidth="50.0" text="ID" />

						<TableColumn fx:id="colNumero" prefWidth="100.0"
							text="Numéro" />

						<TableColumn fx:id="colEmplacement" prefWidth="150.0"
							text="Emplacement" />
						<TableColumn fx:id="colRemarque" prefWidth="200.0"
							text="Remarque" />
						<TableColumn fx:id="colType" prefWidth="100.0"
							text="Type (ID)" />
					</columns>
					<columnResizePolicy>
						<TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
					</columnResizePolicy>
				</TableView>

				<HBox alignment="CENTER_RIGHT" spacing="15.0">
					<children>
						<Button fx:id="btnModifier" disable="true"
							mnemonicParsing="false" onAction="#modifChambre"
							prefHeight="34.0" prefWidth="130.0"
							styleClass="action-btn-warning" text="Modifier" />
						<Button fx:id="btnSupprimer" disable="true"
							mnemonicParsing="false" onAction="#suppChambre" prefHeight="34.0"
							prefWidth="130.0" styleClass="action-btn-danger" text="Supprimer" />
					</children>
				</HBox>

			</children>
		</VBox>
	</center>

</BorderPane>
