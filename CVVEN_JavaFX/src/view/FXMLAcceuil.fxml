<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainContainer" prefHeight="720.0" prefWidth="1180.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.HomeController">

    <stylesheets>
        <URL value="@style.css" />
      <URL value="@../application/application.css" />
    </stylesheets>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="1080.0" spacing="20.0" styleClass="header-panel" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="title-label" text="CVVEN" textFill="WHITE" />
                
                <Separator orientation="VERTICAL" prefHeight="40.0" />
                
                <Label styleClass="subtitle-label" text="Système de Gestion Hôtelière" textFill="#bdc3c7" />
                
                <Region HBox.hgrow="ALWAYS" />
                
                <Label fx:id="lblUtilisateur" style="-fx-font-size: 14px;" text="Utilisateur" textFill="WHITE" />
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefHeight="640.0" prefWidth="299.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-weight: bold; -fx-padding: 0 0 10 10;" text="MENU GÉNÉRAL" textFill="#95a5a6" />
                
                <Button fx:id="btnAcceuil" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goAcceuil" prefHeight="50.0" styleClass="menu-button" text="Acceuil">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>
                
                <Button fx:id="btnChambres" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goChambre" prefHeight="50.0" styleClass="menu-button" text="Gestion des chambres">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>

                <Button fx:id="btnReservations" layoutX="20.0" layoutY="57.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="50.0" styleClass="menu-button" text="Gestion des réservations">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>

                <Button fx:id="btnClients" layoutX="20.0" layoutY="117.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="50.0" styleClass="menu-button" text="Gestion des clients">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>

                <Button fx:id="btnPersonnel" layoutX="20.0" layoutY="177.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="50.0" styleClass="menu-button" text="Gestion du personnel">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>
                
                <Button fx:id="btnFacturation" layoutX="20.0" layoutY="237.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="50.0" styleClass="menu-button" text="Facturation">
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="btnDeconnexion" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="45.0" styleClass="logout-button" text="Déconnexion" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-size: 32px; -fx-font-weight: bold;" text="Bienvenue sur le tableau de bord CVVEN" textFill="#2c3e50" />
                
                <Label style="-fx-font-size: 18px;" text="Sélectionnez une option dans le menu de gauche pour commencer." textFill="#7f8c8d" />
                
                <HBox alignment="CENTER" spacing="30.0" style="-fx-padding: 40 0 0 0;">
                    <children>
                        <VBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" styleClass="stat-card">
                            <children>
                                <Label text="État du système" textFill="#95a5a6" />
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="EN LIGNE" textFill="#27ae60" />
                            </children>
                        </VBox>
                        
                        <VBox alignment="CENTER" layoutX="320.0" layoutY="50.0" prefHeight="100.0" prefWidth="200.0" styleClass="stat-card">
                            <children>
                                <Label text="Date" textFill="#95a5a6" />
                                <Label fx:id="lblDate" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Aujourd'hui" textFill="#2c3e50" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>
